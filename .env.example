# Server
NODE_ENV=development
PORT=3000
RUN_MIGRATIONS=true
HEALTHCHECK_STRICT_EXTERNALS=false
EXTERNAL_CHECK_TIMEOUT_MS=5000
EXTERNAL_CHECK_CACHE_TTL_MS=30000
LIVEKIT_REQUIRED=false
EMAIL_REQUIRED=false
SMS_REQUIRED=false
TRUST_PROXY=1
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ENABLE_PUBLIC_METRICS=true
ENABLE_SWAGGER=true
INTERNAL_OPS_KEY=
REQUIRE_MIGRATIONS_UP_TO_DATE=false
REFRESH_COOKIE_NAME=debate_refresh
REFRESH_COOKIE_DOMAIN=
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_MAX_AGE_MS=2592000000

# PostgreSQL
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/debate
DATABASE_SSL=false
DATABASE_POOL_MAX=20
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000
TEST_DATABASE_URL=postgresql://postgres:your-password@localhost:5432/debate_test

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false
REDIS_KEY_PREFIX=
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_REDIS_PASSWORD=
TEST_REDIS_PREFIX=debate:test

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/oauth/google/callback

# OAuth - Twitter/X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
TWITTER_CALLBACK_URL=http://localhost:3000/auth/oauth/twitter/callback

# LiveKit
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Debate <noreply@debate.com>

# App URLs
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:3000

# Room Settings
DEFAULT_GRACE_PERIOD_SECONDS=30
MAX_SPEAKERS_DEFAULT=6
MIC_REQUEST_COOLDOWN_SECONDS=60
INVITE_EXPIRY_SECONDS=60
EMPTY_ROOM_SWEEP_SECONDS=30
EMPTY_ROOM_MIN_AGE_SECONDS=45
