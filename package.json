{
  "name": "debate-server",
  "version": "1.0.0",
  "description": "Debate Platform - Real-time social voice platform",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "npm run test:unit",
    "test:unit": "jest --testMatch \"**/tests/common/**/*.test.ts\"",
    "test:watch": "jest --watch --testMatch \"**/tests/common/**/*.test.ts\"",
    "test:coverage": "jest --coverage --testMatch \"**/tests/common/**/*.test.ts\"",
    "test:integration": "npm run smoke:infra && npm run smoke:api",
    "test:all": "npm run test:unit && npm run test:integration",
    "smoke:infra": "tsx scripts/smoke-infra.ts",
    "smoke:api": "tsx scripts/smoke-api.ts",
    "preflight:prod": "tsx scripts/preflight-prod.ts",
    "ci": "npm run lint && npm run typecheck && npm run test:unit"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/pg": "^8.16.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^1.2.7",
    "nodemailer": "^8.0.1",
    "otplib": "^12.0.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.19.0",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "prom-client": "^15.1.3",
    "rate-limit-redis": "^4.3.1",
    "socket.io": "^4.7.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "xss": "^1.0.15",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.10",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.11",
    "@types/passport": "^1.0.16",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
